# Database configurations
# If running locally without docker, you can use:
# DATABASE_URL=sqlite:///./smarterp.db
# If running with docker-compose:
DATABASE_URL=postgresql://postgres:postgres@db:5432/smarterp

# JWT security configurations
SECRET_KEY=smarterp_super_secret_key_change_me_in_production_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Vector Database Path (ChromaDB)
CHROMA_DB_PATH=./chroma_db
